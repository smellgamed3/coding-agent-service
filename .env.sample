# =============================================================================
# coding-agent-service 环境变量配置示例
# 使用方法：复制本文件为 .env，填入实际值后通过 docker-compose 或 docker run 加载
# =============================================================================

# -----------------------------------------------------------------------------
# [Claude Code] LLM Provider 配置
# 文档：https://docs.anthropic.com/en/docs/claude-code/setup
# -----------------------------------------------------------------------------

# Anthropic API Key（使用 claude-code 时必填）
ANTHROPIC_API_KEY=

# 自定义 API Base URL（可选，用于代理或兼容接口，默认为官方 Anthropic API）
# 示例：https://your-proxy.example.com
ANTHROPIC_BASE_URL=

# 指定 Claude 模型名称（可选，默认由 claude-code 自动选择最新模型）
# 常用值：claude-opus-4-5、claude-sonnet-4-5、claude-haiku-4-5
ANTHROPIC_MODEL=

# -----------------------------------------------------------------------------
# [OpenCode] LLM Provider 配置
# OpenCode 支持多种 Provider，通过以下环境变量控制
# 文档：https://www.npmjs.com/package/opencode-ai
# -----------------------------------------------------------------------------

# --- Anthropic Provider（opencode 使用 Anthropic 时）---
# 若 ANTHROPIC_API_KEY 已在上方填写，此处可留空（opencode 会复用同名变量）

# --- OpenAI / OpenAI-兼容 Provider ---

# OpenAI API Key（使用 opencode + OpenAI 模型时填写）
OPENAI_API_KEY=

# OpenAI API Base URL（可选，用于 OpenAI-兼容接口，如 Azure OpenAI、本地 Ollama 等）
# 示例（Azure）：https://your-resource.openai.azure.com/openai/deployments/your-deployment
# 示例（本地）：http://host.docker.internal:11434/v1
OPENAI_BASE_URL=

# OpenAI 模型名称（可选）
# 常用值：gpt-4o、gpt-4o-mini、o1、o3-mini
OPENAI_MODEL=

# --- 其他兼容 Provider（如 DeepSeek、Groq、Gemini 等）---

# API Key（OpenAI-兼容 Provider 通用 Key，优先级低于 OPENAI_API_KEY）
OPENCODE_API_KEY=

# Base URL（OpenAI-兼容 Provider 通用 Base URL，优先级低于 OPENAI_BASE_URL）
OPENCODE_BASE_URL=

# 模型名称（OpenAI-兼容 Provider 通用模型名）
OPENCODE_MODEL=

# -----------------------------------------------------------------------------
# [服务] 运行参数
# -----------------------------------------------------------------------------

# 服务监听端口（默认 8000，通常无需修改，通过 compose ports 映射即可）
# SERVICE_PORT=8000
